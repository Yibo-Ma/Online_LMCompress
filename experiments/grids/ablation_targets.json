{
  "group_name": "text_ablation_targets",
  "note": "Stage-4 ablation: LoRA target-module coverage (attn-only -> +MLP), all else = Stage-1 winner. Replace 'fixed' with best_config.json values (minus target_modules). Same pattern works for any single-axis ablation.",
  "modality": "text",
  "fixed": {
    "model": "checkpoints/Qwen2.5-0.5B",
    "data": "data/text/normalized/qwen2.5/pile_of_law_eurlex",
    "max_bytes": 16000000,
    "chunk_size": 2048,
    "train_interval": 8,
    "epochs_per_train": 2,
    "lr": 1e-04,
    "lora_r": 16,
    "lora_alpha": 32,
    "batch_chunks": 8,
    "base_seed": 42,
    "lora_dropout": 0.0,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "train_on_all": false,
    "no_decompress": true
  },
  "grid": {
    "target_modules": [
      "q_proj,v_proj",
      "q_proj,k_proj,v_proj,o_proj",
      "q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj"
    ]
  }
}
