{
  "group_name": "image_stage1",
  "note": "Stage-1 search on CLIC (bGPT image, c_attn LoRA). 256px crops keep each run fast for ranking; Stage 3 uses full images. Compress-only, recent-only. image_count over-provisions and degrades to whatever the dir holds.",
  "modality": "image",
  "fixed": {
    "model": "checkpoints/bgpt/weights-image.pth",
    "data": "data/image/clic2024",
    "image_px": 32,
    "image_count": 24,
    "image_crop": 256,
    "batch_chunks": 8,
    "base_seed": 42,
    "lora_dropout": 0.0,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "train_on_all": false,
    "no_decompress": true
  },
  "grid": {
    "train_interval": [4, 8, 16],
    "epochs_per_train": [1, 2, 3],
    "lr": [3e-05, 1e-04, 3e-04],
    "lora_r": [8, 16, 32],
    "target_modules": ["c_attn"]
  }
}
